<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FFXIVSpanishPatcher.App.ViewModels"
        x:Class="FFXIVSpanishPatcher.App.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/icon.ico"
        Title="{Binding WindowTitle}"
        Width="1180" Height="780" MinWidth="1010" MinHeight="600"
        Background="#0B1120">

  <Window.Resources>
    <SolidColorBrush x:Key="Accent" Color="#2563EB"/>
    <SolidColorBrush x:Key="Panel" Color="#151C2C"/>
    <SolidColorBrush x:Key="PanelBorder" Color="#26304A"/>
    <SolidColorBrush x:Key="ConsoleBg" Color="#0D1422"/>
    <SolidColorBrush x:Key="Muted" Color="#9AA4B2"/>
    <SolidColorBrush x:Key="Text" Color="#E6EAF2"/>
    <SolidColorBrush x:Key="ControlBlue" Color="#1E2840"/>
    <SolidColorBrush x:Key="ControlBlueHover" Color="#253456"/>
    <SolidColorBrush x:Key="ControlBluePressed" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="ControlBlueBorder" Color="#34446A"/>
  </Window.Resources>

  <Window.Styles>
    <Style Selector="TextBlock.h2">
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{StaticResource Text}"/>
    </Style>
    <Style Selector="Border.card">
      <Setter Property="Background" Value="{StaticResource Panel}"/>
      <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="18"/>
    </Style>
    <Style Selector="Button">
      <Setter Property="Background" Value="{StaticResource ControlBlue}"/>
      <Setter Property="BorderBrush" Value="{StaticResource ControlBlueBorder}"/>
      <Setter Property="Foreground" Value="{StaticResource Text}"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>
    <Style Selector="Button:pointerover">
      <Setter Property="Background" Value="{StaticResource ControlBlueHover}"/>
      <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
    </Style>
    <Style Selector="Button:pressed">
      <Setter Property="Background" Value="{StaticResource ControlBluePressed}"/>
      <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{StaticResource Accent}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Height" Value="48"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>
    <Style Selector="Button.primary:disabled">
      <Setter Property="Opacity" Value="0.45"/>
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="#1E2840"/>
      <Setter Property="Foreground" Value="{StaticResource Text}"/>
      <Setter Property="Height" Value="48"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>
  </Window.Styles>

  <DockPanel>
    <!-- Status bar -->
    <Border DockPanel.Dock="Bottom" Background="#0E1525" BorderBrush="{StaticResource PanelBorder}"
            BorderThickness="0,1,0,0" Padding="18,10">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto">
        <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{StaticResource Muted}"
                   Text="{Binding LastOutputName, StringFormat='Salida: {0}', FallbackValue='Salida: —'}"/>
        <Border Grid.Column="1" Margin="12,0,0,0" CornerRadius="6" Padding="10,3" VerticalAlignment="Center"
                IsVisible="{Binding LastSuccess}"
                Background="#14361F">
          <TextBlock Text="{Binding StatusText}" Foreground="#4ADE80" FontWeight="SemiBold"/>
        </Border>
        <TextBlock Grid.Column="2" Margin="20,0" VerticalAlignment="Center" Foreground="{StaticResource Muted}"
                   TextTrimming="CharacterEllipsis"
                   Text="{Binding OutputFolder, StringFormat='Carpeta de salida: {0}'}"/>
        <Button Grid.Column="3" Margin="0,0,14,0" VerticalAlignment="Center" Padding="4,2"
                Background="Transparent" BorderThickness="0"
                Foreground="{StaticResource Muted}" FontSize="12" Cursor="Hand"
                Content="Aviso legal">
          <Button.Flyout>
            <Flyout Placement="TopEdgeAlignedRight">
              <ScrollViewer MaxHeight="320" MaxWidth="460">
                <StackPanel Spacing="8" Margin="4">
                  <TextBlock Text="Aviso legal" FontWeight="SemiBold" FontSize="14"
                             Foreground="{StaticResource Text}"/>
                  <SelectableTextBlock Text="{Binding LegalNoticeText}" TextWrapping="Wrap"
                                       FontSize="12" Foreground="{StaticResource Muted}"
                                       SelectionBrush="{StaticResource Accent}" MaxWidth="430"/>
                </StackPanel>
              </ScrollViewer>
            </Flyout>
          </Button.Flyout>
        </Button>
        <TextBlock Grid.Column="4" Margin="0,0,14,0" VerticalAlignment="Center"
                   Foreground="{StaticResource Muted}"
                   Text="{Binding AppVersionLabel, StringFormat='Versión: {0}'}"/>
        <Button Grid.Column="5" Content="Copiar log" Command="{Binding CopyLogCommand}"/>
      </Grid>
    </Border>

    <!-- Body: two columns -->
    <Grid Margin="18" ColumnDefinitions="*,420" RowDefinitions="*">

      <!-- Left column -->
      <Grid Grid.Column="0" Margin="0,0,18,0" RowDefinitions="Auto,*">

        <Border Grid.Row="0" Classes="card" Margin="0,0,0,16">
          <StackPanel Spacing="10">
            <TextBlock Classes="h2" Text="Ruta del juego (FFXIV)"/>
            <Grid ColumnDefinitions="*,Auto" >
              <TextBox Grid.Column="0" Text="{Binding GamePath}" Watermark="C:\...\FINAL FANTASY XIV - A Realm Reborn"/>
              <Button Grid.Column="1" Margin="10,0,0,0" Content="Examinar..." Command="{Binding BrowseCommand}"/>
            </Grid>
            <TextBlock Foreground="{StaticResource Muted}" FontSize="12"
                       Text="Se intenta detectar automáticamente. Puedes cambiarla manualmente si es necesario."/>
            <Grid ColumnDefinitions="210,*" Margin="0,6,0,0">
              <Button Grid.Column="0" Classes="primary" Width="210" Margin="0,0,8,0"
                      Command="{Binding GenerateModCommand}">
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <Path Width="18" Height="18" Stretch="Uniform" Stroke="White" StrokeThickness="2"
                        StrokeLineCap="Round" StrokeJoin="Round"
                        Data="M12 15.5 A3.5 3.5 0 1 0 12 8.5 A3.5 3.5 0 0 0 12 15.5 Z M19.4 15 A1.65 1.65 0 0 0 19.73 16.82 L19.79 16.92 A2 2 0 0 1 19.06 19.65 L18.94 19.72 A2 2 0 0 1 16.21 18.99 L16.15 18.89 A1.65 1.65 0 0 0 14.55 18 H14.45 A1.65 1.65 0 0 0 12.85 18.89 L12.79 18.99 A2 2 0 0 1 10.06 19.72 L9.94 19.65 A2 2 0 0 1 9.21 16.92 L9.27 16.82 A1.65 1.65 0 0 0 9.6 15 V14.9 A1.65 1.65 0 0 0 8.33 13.29 L8.22 13.24 A2 2 0 0 1 8.22 10.76 L8.33 10.71 A1.65 1.65 0 0 0 9.6 9.1 V9 A1.65 1.65 0 0 0 9.27 7.18 L9.21 7.08 A2 2 0 0 1 9.94 4.35 L10.06 4.28 A2 2 0 0 1 12.79 5.01 L12.85 5.11 A1.65 1.65 0 0 0 14.45 6 H14.55 A1.65 1.65 0 0 0 16.15 5.11 L16.21 5.01 A2 2 0 0 1 18.94 4.28 L19.06 4.35 A2 2 0 0 1 19.79 7.08 L19.73 7.18 A1.65 1.65 0 0 0 19.4 9 V9.1 A1.65 1.65 0 0 0 20.67 10.71 L20.78 10.76 A2 2 0 0 1 20.78 13.24 L20.67 13.29 A1.65 1.65 0 0 0 19.4 14.9 Z"/>
                  <TextBlock Text="Generar mod" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <Button Grid.Column="1" Classes="secondary" Width="220" Margin="8,0,0,0"
                      Command="{Binding OpenOutputFolderCommand}">
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <Path Width="19" Height="17" Stretch="Uniform" Stroke="White" StrokeThickness="2"
                        StrokeLineCap="Round" StrokeJoin="Round"
                        Data="M3 6 H8 L10 8 H21 V19 A2 2 0 0 1 19 21 H5 A2 2 0 0 1 3 19 Z M3 6 V5 A2 2 0 0 1 5 3 H8 L10 5 H19 A2 2 0 0 1 21 7 V8"/>
                  <TextBlock Text="Abrir carpeta de salida" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
            </Grid>
          </StackPanel>
        </Border>

        <Border Grid.Row="1" Classes="card">
          <DockPanel>
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
              <TextBlock Classes="h2" Text="Consola"/>
              <Button Grid.Column="1" Content="Limpiar" Command="{Binding ClearConsoleCommand}"/>
            </Grid>
            <Border Background="{StaticResource ConsoleBg}" CornerRadius="8" Padding="12">
              <ScrollViewer Name="ConsoleScroll">
                <ItemsControl ItemsSource="{Binding Console}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ConsoleLine">
                      <SelectableTextBlock Text="{Binding Text}" Foreground="{Binding Foreground}"
                                           SelectionBrush="{StaticResource Accent}"
                                           FontFamily="Cascadia Mono,Consolas,monospace" FontSize="12.5"
                                           TextWrapping="Wrap" Margin="0,1"/>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Border>
          </DockPanel>
        </Border>
      </Grid>

      <!-- Right column -->
      <ScrollViewer Grid.Column="1">
        <StackPanel Spacing="16">

          <Border Classes="card">
            <StackPanel Spacing="6">
              <TextBlock Classes="h2" Text="Opciones avanzadas"/>
              <TextBlock Foreground="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap"
                         Text="Selecciona manualmente qué categorías EXD incluir en el parche. Todas están seleccionadas por defecto."/>
            </StackPanel>
          </Border>

          <Border Classes="card">
            <StackPanel Spacing="12">
              <TextBlock Classes="h2" Text="Categorías EXD"/>
              <ItemsControl ItemsSource="{Binding Categories}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:CategoryViewModel">
                    <CheckBox IsChecked="{Binding IsSelected}" IsEnabled="{Binding IsEnabled}"
                              ToolTip.Tip="{Binding Tooltip}" Margin="0,2">
                      <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Label}" Foreground="{StaticResource Text}"/>
                        <TextBlock Text="{Binding Count, StringFormat=' ({0})'}"
                                   Foreground="{StaticResource Muted}" Margin="6,0,0,0"/>
                      </StackPanel>
                    </CheckBox>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <Border Classes="card">
            <StackPanel Spacing="10">
              <TextBlock Classes="h2" Text="Opciones adicionales"/>
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                  <TextBlock Text="Verificar integridad al finalizar" Foreground="{StaticResource Text}"/>
                  <TextBlock Text="Comprueba que los archivos generados sean válidos."
                             Foreground="{StaticResource Muted}" FontSize="12"/>
                </StackPanel>
                <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding VerifyIntegrity}"/>
              </Grid>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>
    </Grid>
  </DockPanel>
</Window>
