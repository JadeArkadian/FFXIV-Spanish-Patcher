<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FFXIVSpanishPatcher.App.ViewModels"
        x:Class="FFXIVSpanishPatcher.App.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/icon.ico"
        Title="FFXIVSpanish Patcher"
        Width="1180" Height="720" MinWidth="960" MinHeight="600"
        Background="#0B1120">

  <Window.Resources>
    <SolidColorBrush x:Key="Accent" Color="#2563EB"/>
    <SolidColorBrush x:Key="Panel" Color="#151C2C"/>
    <SolidColorBrush x:Key="PanelBorder" Color="#26304A"/>
    <SolidColorBrush x:Key="ConsoleBg" Color="#0D1422"/>
    <SolidColorBrush x:Key="Muted" Color="#9AA4B2"/>
    <SolidColorBrush x:Key="Text" Color="#E6EAF2"/>
  </Window.Resources>

  <Window.Styles>
    <Style Selector="TextBlock.h2">
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{StaticResource Text}"/>
    </Style>
    <Style Selector="Border.card">
      <Setter Property="Background" Value="{StaticResource Panel}"/>
      <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="18"/>
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{StaticResource Accent}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Height" Value="48"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>
    <Style Selector="Button.primary:disabled">
      <Setter Property="Opacity" Value="0.45"/>
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="#1E2840"/>
      <Setter Property="Foreground" Value="{StaticResource Text}"/>
      <Setter Property="Height" Value="48"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>
  </Window.Styles>

  <DockPanel>
    <!-- Status bar -->
    <Border DockPanel.Dock="Bottom" Background="#0E1525" BorderBrush="{StaticResource PanelBorder}"
            BorderThickness="0,1,0,0" Padding="18,10">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto">
        <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{StaticResource Muted}"
                   Text="{Binding LastOutputName, StringFormat='Salida: {0}', FallbackValue='Salida: —'}"/>
        <Border Grid.Column="1" Margin="12,0,0,0" CornerRadius="6" Padding="10,3" VerticalAlignment="Center"
                IsVisible="{Binding LastSuccess}"
                Background="#14361F">
          <TextBlock Text="{Binding StatusText}" Foreground="#4ADE80" FontWeight="SemiBold"/>
        </Border>
        <TextBlock Grid.Column="2" Margin="20,0" VerticalAlignment="Center" Foreground="{StaticResource Muted}"
                   TextTrimming="CharacterEllipsis"
                   Text="{Binding OutputFolder, StringFormat='Carpeta de salida: {0}'}"/>
        <Button Grid.Column="3" Content="Copiar log" Command="{Binding CopyLogCommand}"/>
      </Grid>
    </Border>

    <!-- Body: two columns -->
    <Grid Margin="18" ColumnDefinitions="*,420" RowDefinitions="*">

      <!-- Left column -->
      <Grid Grid.Column="0" Margin="0,0,18,0" RowDefinitions="Auto,*">

        <Border Grid.Row="0" Classes="card" Margin="0,0,0,16">
          <StackPanel Spacing="10">
            <TextBlock Classes="h2" Text="Ruta del juego (FFXIV)"/>
            <Grid ColumnDefinitions="*,Auto" >
              <TextBox Grid.Column="0" Text="{Binding GamePath}" Watermark="C:\...\FINAL FANTASY XIV - A Realm Reborn"/>
              <Button Grid.Column="1" Margin="10,0,0,0" Content="Examinar..." Command="{Binding BrowseCommand}"/>
            </Grid>
            <TextBlock Foreground="{StaticResource Muted}" FontSize="12"
                       Text="Se intenta detectar automáticamente. Puedes cambiarla manualmente si es necesario."/>
            <Grid ColumnDefinitions="*,*" Margin="0,6,0,0">
              <Button Grid.Column="0" Classes="primary" Margin="0,0,8,0"
                      Content="Generar mod" Command="{Binding GenerateModCommand}"/>
              <Button Grid.Column="1" Classes="secondary" Margin="8,0,0,0"
                      Content="Abrir carpeta de salida" Command="{Binding OpenOutputFolderCommand}"/>
            </Grid>
          </StackPanel>
        </Border>

        <Border Grid.Row="1" Classes="card">
          <DockPanel>
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
              <TextBlock Classes="h2" Text="Consola"/>
              <Button Grid.Column="1" Content="Limpiar" Command="{Binding ClearConsoleCommand}"/>
            </Grid>
            <Border Background="{StaticResource ConsoleBg}" CornerRadius="8" Padding="12">
              <ScrollViewer Name="ConsoleScroll">
                <ItemsControl ItemsSource="{Binding Console}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ConsoleLine">
                      <TextBlock Text="{Binding Text}" Foreground="{Binding Foreground}"
                                 FontFamily="Cascadia Mono,Consolas,monospace" FontSize="12.5"
                                 TextWrapping="Wrap" Margin="0,1"/>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Border>
          </DockPanel>
        </Border>
      </Grid>

      <!-- Right column -->
      <ScrollViewer Grid.Column="1">
        <StackPanel Spacing="16">

          <Border Classes="card">
            <StackPanel Spacing="6">
              <TextBlock Classes="h2" Text="Opciones avanzadas"/>
              <TextBlock Foreground="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap"
                         Text="Selecciona manualmente qué categorías EXD incluir en el parche. Todas están seleccionadas por defecto."/>
            </StackPanel>
          </Border>

          <Border Classes="card">
            <StackPanel Spacing="12">
              <TextBlock Classes="h2" Text="Categorías EXD"/>
              <ItemsControl ItemsSource="{Binding Categories}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:CategoryViewModel">
                    <CheckBox IsChecked="{Binding IsSelected}" IsEnabled="{Binding IsEnabled}"
                              ToolTip.Tip="{Binding Tooltip}" Margin="0,2">
                      <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Label}" Foreground="{StaticResource Text}"/>
                        <TextBlock Text="{Binding Count, StringFormat=' ({0})'}"
                                   Foreground="{StaticResource Muted}" Margin="6,0,0,0"/>
                      </StackPanel>
                    </CheckBox>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <Border Classes="card">
            <StackPanel Spacing="10">
              <TextBlock Classes="h2" Text="Opciones adicionales"/>
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                  <TextBlock Text="Verificar integridad al finalizar" Foreground="{StaticResource Text}"/>
                  <TextBlock Text="Comprueba que los archivos generados sean válidos."
                             Foreground="{StaticResource Muted}" FontSize="12"/>
                </StackPanel>
                <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding VerifyIntegrity}"/>
              </Grid>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>
    </Grid>
  </DockPanel>
</Window>
